---
import { getImagePath } from "astro-opengraph-images";
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import FormattedDate from "../components/FormattedDate.astro";
import { SITE_TITLE, SITE_URL } from "../consts";

type Props = CollectionEntry<"blog">["data"] & {
  readingTime?: number;
  headings?: { depth: number; slug: string; text: string }[];
};

const { title, description, pubDate, updatedDate, heroImage, readingTime, headings } = Astro.props;
const hasTableOfContents = headings && headings.filter((h) => h.depth <= 3).length > 2;
const openGraphImage = getImagePath({ url: Astro.url, site: Astro.site });
const structuredDataImage = heroImage
  ? new URL(heroImage.src, Astro.url).toString()
  : openGraphImage;
const articleStructuredData = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  description,
  image: [structuredDataImage],
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  author: {
    "@type": "Person",
    name: "Nitish Sharma",
    url: SITE_URL,
  },
  publisher: {
    "@type": "Person",
    name: "Nitish Sharma",
    url: SITE_URL,
  },
  isPartOf: {
    "@type": "Blog",
    name: `${SITE_TITLE} Blog`,
    url: new URL("/blog/", SITE_URL).toString(),
  },
  mainEntityOfPage: Astro.url.toString(),
  url: Astro.url.toString(),
};
---

<html lang="en" class="scroll-smooth">
  <head>
    <BaseHead
      title={title}
      description={description}
      type="article"
      publishedTime={pubDate}
      modifiedTime={updatedDate ?? pubDate}
      structuredData={articleStructuredData}
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Inter:ital,opsz,wght@0,14..32,300..800;1,14..32,300..800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="antialiased">
    <div id="spotlight"></div>
    <div id="reading-progress" class="fixed top-0 left-0 h-[2px] bg-accent z-[100]" style="width: 0%"></div>

    <div class="mx-auto min-h-screen max-w-screen-xl px-6 py-12 md:px-12 md:py-20 lg:px-24">
      <nav class="mb-16 nav-enter">
        <a
          href="/"
          class="group inline-flex items-center gap-2 text-sm font-semibold text-accent hover:underline"
        >
          <svg class="h-4 w-4 transition-transform group-hover:-translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M7 7h10M7 7v10" transform="rotate(180 12 12)"/>
          </svg>
          Nitish Sharma
        </a>
      </nav>

      <main class="pb-20">
        <article class="relative">
          <header
            class:list={[
              "mb-12 w-full",
            ]}
          >
            <div class="flex items-center gap-3 text-sm text-muted mb-6">
              <FormattedDate date={pubDate} />
              {readingTime && (
                <>
                  <span class="text-muted">&middot;</span>
                  <span>{readingTime} min read</span>
                </>
              )}
              {updatedDate && (
                <>
                  <span class="text-muted">&middot;</span>
                  <span>Updated <FormattedDate date={updatedDate} /></span>
                </>
              )}
            </div>
            <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-6 leading-[1.1] text-bright">
              {title}
            </h1>
            {description && (
              <p class="text-xl text-muted leading-relaxed font-light">
                {description}
              </p>
            )}
          </header>

          <div class="max-w-7xl">
            <div class="flex gap-8 lg:gap-12">
              {hasTableOfContents && (
                <aside class="hidden xl:block w-64 shrink-0">
                  <nav class="sticky top-24">
                    <p class="text-xs font-semibold uppercase tracking-widest text-muted mb-4">On this page</p>
                    <ul class="space-y-2 text-sm border-l border-[rgba(255,255,255,0.08)]">
                      {headings?.filter((h) => h.depth <= 3).map((heading) => (
                        <li>
                          <a
                            href={`#${heading.slug}`}
                            class:list={[
                              "block py-1 text-muted hover:text-bright transition-colors border-l-2 -ml-[2px]",
                              "border-transparent hover:border-accent",
                              heading.depth === 2 ? "pl-4" : "pl-8",
                            ]}
                            data-toc-link
                          >
                            {heading.text}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </nav>
                </aside>
              )}

              <div class="flex-1 min-w-0">
                <div class="prose">
                  <slot />
                </div>

                <hr class="border-[rgba(255,255,255,0.08)] my-16" />

                <div class="flex flex-col sm:flex-row items-center justify-between gap-6">
                  <div class="flex items-center gap-4">
                    <div class="w-12 h-12 rounded-full bg-bg-card border border-[rgba(255,255,255,0.1)] flex items-center justify-center">
                      <span class="text-accent font-bold text-xl leading-none">N</span>
                    </div>
                    <div>
                      <p class="font-semibold text-bright">Nitish Sharma</p>
                      <p class="text-sm text-muted">Full-Stack Engineer</p>
                    </div>
                  </div>

                  <div class="flex items-center gap-3">
                    <span class="text-sm text-muted">Share</span>
                    <button
                      id="share-twitter"
                      class="w-10 h-10 rounded-full bg-bg-card hover:bg-bg-card-hover flex items-center justify-center transition-colors text-muted hover:text-bright"
                      aria-label="Share on Twitter"
                    >
                      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path></svg>
                    </button>
                    <button
                      id="share-linkedin"
                      class="w-10 h-10 rounded-full bg-bg-card hover:bg-bg-card-hover flex items-center justify-center transition-colors text-muted hover:text-bright"
                      aria-label="Share on LinkedIn"
                    >
                      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path></svg>
                    </button>
                    <button
                      id="copy-link"
                      class="w-10 h-10 rounded-full bg-bg-card hover:bg-bg-card-hover flex items-center justify-center transition-colors text-muted hover:text-bright group relative"
                      aria-label="Copy link"
                    >
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path></svg>
                      <span class="absolute -top-10 left-1/2 -translate-x-1/2 px-2 py-1 bg-bg-card-hover text-bright text-xs rounded opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none whitespace-nowrap">
                        Copy link
                      </span>
                    </button>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </article>
      </main>

      <footer class="pt-8 border-t border-[rgba(255,255,255,0.08)] text-sm text-muted pb-16">
        <p>&copy; {new Date().getFullYear()} Nitish Sharma</p>
      </footer>
    </div>

    <script>
      const spotlight = document.getElementById("spotlight") as HTMLCanvasElement | null;
      if (spotlight) {
        const canvas = document.createElement("canvas");
        canvas.style.cssText = "position:fixed;inset:0;width:100%;height:100%;pointer-events:none;z-index:1";
        spotlight.replaceWith(canvas);
        const ctx = canvas.getContext("2d")!;
        let mouseX = -1000, mouseY = -1000;
        let curX = -1000, curY = -1000;
        const resize = () => { canvas.width = window.innerWidth; canvas.height = window.innerHeight; };
        resize();
        window.addEventListener("resize", resize);
        document.addEventListener("mousemove", (e) => { mouseX = e.clientX; mouseY = e.clientY; });
        const draw = () => {
          curX += (mouseX - curX) * 0.15;
          curY += (mouseY - curY) * 0.15;
          ctx.clearRect(0, 0, canvas.width, canvas.height);
          const gradient = ctx.createRadialGradient(curX, curY, 0, curX, curY, 600);
          gradient.addColorStop(0, "rgba(255, 255, 255, 0.04)");
          gradient.addColorStop(1, "transparent");
          ctx.fillStyle = gradient;
          ctx.fillRect(0, 0, canvas.width, canvas.height);
          requestAnimationFrame(draw);
        };
        requestAnimationFrame(draw);
      }

      const progressBar = document.getElementById("reading-progress");
      if (progressBar) {
        const updateProgress = () => {
          const scrollTop = window.scrollY;
          const docHeight = document.documentElement.scrollHeight;
          const winHeight = window.innerHeight;
          const scrollPercent = scrollTop / (docHeight - winHeight);
          progressBar.style.width = `${Math.min(scrollPercent * 100, 100)}%`;
        };
        window.addEventListener("scroll", updateProgress, { passive: true });
        updateProgress();
      }

      const tocLinks = document.querySelectorAll("[data-toc-link]");
      if (tocLinks.length > 0) {
        const headings = Array.from(document.querySelectorAll(".prose h2, .prose h3")) as HTMLElement[];
        const headingMap = new Map(
          headings.map((heading) => [
            heading.id,
            document.querySelector(`[data-toc-link][href="#${heading.id}"]`) as HTMLAnchorElement | null,
          ]),
        );

        const setActiveTocLink = (activeId: string | null) => {
          tocLinks.forEach((link) => {
            link.classList.remove("text-bright", "border-accent");
            link.classList.add("text-muted", "border-transparent");
          });
          if (!activeId) return;
          const activeLink = headingMap.get(activeId);
          if (activeLink) {
            activeLink.classList.remove("text-muted", "border-transparent");
            activeLink.classList.add("text-bright", "border-accent");
          }
        };

        const updateActiveHeadingByScroll = () => {
          const viewportAnchor = window.scrollY + window.innerHeight * 0.25;
          let activeId: string | null = null;

          for (const heading of headings) {
            if (heading.offsetTop <= viewportAnchor) {
              activeId = heading.id;
            } else {
              break;
            }
          }

          setActiveTocLink(activeId ?? headings[0]?.id ?? null);
        };

        window.addEventListener("scroll", updateActiveHeadingByScroll, { passive: true });
        window.addEventListener("resize", updateActiveHeadingByScroll);
        updateActiveHeadingByScroll();
      }

      const shareTwitter = document.getElementById("share-twitter");
      const shareLinkedin = document.getElementById("share-linkedin");
      const copyLink = document.getElementById("copy-link");
      const pageUrl = encodeURIComponent(window.location.href);
      const pageTitle = encodeURIComponent(document.title);

      shareTwitter?.addEventListener("click", () => {
        window.open(`https://twitter.com/intent/tweet?url=${pageUrl}&text=${pageTitle}`, "_blank", "width=550,height=420");
      });
      shareLinkedin?.addEventListener("click", () => {
        window.open(`https://www.linkedin.com/sharing/share-offsite/?url=${pageUrl}`, "_blank", "width=550,height=420");
      });
      copyLink?.addEventListener("click", async () => {
        await navigator.clipboard.writeText(window.location.href);
        const tooltip = copyLink.querySelector("span");
        if (tooltip) {
          tooltip.textContent = "Copied!";
          setTimeout(() => { tooltip.textContent = "Copy link"; }, 2000);
        }
      });
    </script>
  </body>
</html>

<style is:global>
  .prose {
    color: #8a8a97;
    font-family: "Lora", Georgia, "Times New Roman", serif;
    font-size: 1.125rem;
    line-height: 1.85;
    letter-spacing: -0.003em;
  }

  .prose > * + * { margin-top: 1.5em; }
  .prose p { margin-bottom: 0; }

  .prose h1, .prose h2, .prose h3, .prose h4, .prose h5, .prose h6 {
    color: #ededef;
    font-family: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.3;
    scroll-margin-top: 6rem;
  }

  .prose h2 {
    font-size: 1.875rem;
    margin-top: 3rem;
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.15);
  }

  .prose h3 { font-size: 1.5rem; margin-top: 2.5rem; margin-bottom: 0.75rem; }
  .prose h4 { font-size: 1.25rem; margin-top: 2rem; margin-bottom: 0.5rem; }

  .prose a {
    color: #ededef;
    text-decoration: underline;
    text-decoration-color: rgba(255, 255, 255, 0.3);
    text-underline-offset: 3px;
    transition: all 0.2s ease;
  }
  .prose a:hover { text-decoration-color: #ededef; }

  .prose strong { color: #ededef; font-weight: 600; }

  .prose code {
    background-color: #111113;
    padding: 0.2em 0.4em;
    border-radius: 6px;
    font-size: 0.875em;
    color: #ededef;
    font-family: "SF Mono", "Fira Code", "Consolas", monospace;
  }

  .prose pre {
    background: #111113;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    padding: 1.5em;
    overflow-x: auto;
    margin: 2em 0;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.3);
  }

  .prose pre code {
    background: none;
    padding: 0;
    color: #b4b4be;
    font-size: 0.9em;
    line-height: 1.7;
  }

  .prose blockquote {
    position: relative;
    border: none;
    padding: 1.5em 2em;
    margin: 2em 0;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0.02));
    border-radius: 12px;
    font-size: 1.125em;
    font-style: italic;
    color: #b4b4be;
  }

  .prose blockquote::before {
    content: "\201C";
    position: absolute;
    top: -0.2em;
    left: 0.3em;
    font-size: 4em;
    color: rgba(255, 255, 255, 0.15);
    font-family: Georgia, serif;
    line-height: 1;
  }

  .prose blockquote p { margin: 0; position: relative; z-index: 1; }

  .prose ul, .prose ol { padding-left: 1.5em; }
  .prose ul { list-style: none; }

  .prose ul li {
    position: relative;
    padding-left: 0.5em;
    margin-bottom: 0.75em;
  }

  .prose ul li::before {
    content: "";
    position: absolute;
    left: -1em;
    top: 0.65em;
    width: 6px;
    height: 6px;
    background: #ededef;
    border-radius: 50%;
  }

  .prose ol { list-style: none; counter-reset: ol-counter; }

  .prose ol li {
    position: relative;
    padding-left: 0.5em;
    margin-bottom: 0.75em;
    counter-increment: ol-counter;
  }

  .prose ol li::before {
    content: counter(ol-counter);
    position: absolute;
    left: -1.5em;
    top: 0;
    font-size: 0.875em;
    font-weight: 700;
    color: #ededef;
  }

  .prose hr {
    border: none;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
    margin: 3em 0;
  }

  .prose img {
    border-radius: 16px;
    margin: 2em 0;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
  }

  .prose > p:first-of-type { font-size: 1.25em; line-height: 1.7; color: #b4b4be; }

  .prose > p:first-of-type::first-letter {
    float: left;
    font-size: 3.5em;
    line-height: 0.8;
    font-weight: 700;
    margin-right: 0.1em;
    margin-top: 0.1em;
    color: #ededef;
  }

  @media (max-width: 640px) {
    .prose { font-size: 1.0625rem; }
    .prose h2 { font-size: 1.5rem; }
    .prose h3 { font-size: 1.25rem; }
    .prose blockquote { padding: 1em 1.25em; }
    .prose blockquote::before { font-size: 3em; }
  }
</style>
